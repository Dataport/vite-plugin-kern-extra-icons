{
	"name": "vite-plugin-kern-extra-icons",
	"version": "0.0.0-development",
	"description": "Vite plugin to load material icons not bundled with @kern-ux/native dynamically",
	"keywords": [
		"KERN",
		"vite-plugin"
	],
	"license": "EUPL-1.2",
	"type": "module",
	"author": "Dataport AöR <polar@dataport.de>",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./client": {
			"types": "./src/client.d.ts"
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Dataport/vite-plugin-kern-extra-icons.git"
	},
	"scripts": {
		"start": "vite --config example/vite.config.ts",
		"build": "tsc -p tsconfig.build.json",
		"lint": "eslint --cache .",
		"lint:ci": "eslint .",
		"lint:fix": "eslint --cache --fix .",
		"test": "echo OK",
		"tsc": "tsc --noEmit",
		"prepare": "husky",
		"preversion": "npm run lint && npm run test && npm run build",
		"version": "conventional-changelog -r 1 -p conventionalcommits -t v && git add CHANGELOG.md"
	},
	"files": [
		"dist/**/*",
		"src/**/*.d.ts",
		"README.md"
	],
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@dataport/eslint-config-geodev": "^1.0.0-alpha.3",
		"@kern-ux/native": "^2.6.2",
		"@types/node": "^26.0.1",
		"conventional-changelog": "^7.1.1",
		"conventional-changelog-conventionalcommits": "^9.1.0",
		"typescript": "^7.0.2",
		"vite": "^8.0.14"
	},
	"peerDependencies": {
		"vite": "^8.0.8"
	},
	"dependencies": {
		"@material-symbols/svg-400": "^0.44.0",
		"husky": "^9.1.7"
	}
}
